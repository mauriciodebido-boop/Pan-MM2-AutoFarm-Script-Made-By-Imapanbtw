-- ==========================================
-- 4. GROUND-UP REWRITTEN NAVIGATION ENGINE
-- ==========================================
local function physicallyWalkTo(targetPosition, isWandering)
    local character = player.Character
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if not humanoid or not hrp or humanoid.Health <= 0 then return false end

    -- Lower the speed slightly during wanders to make it look casual and natural
    humanoid.WalkSpeed = isWandering and (Config.WalkSpeed * 0.75) or Config.WalkSpeed

    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    rayParams.FilterDescendantsInstances = {character, workspace:FindFirstChild("CoinContainer", true)}

    local currentDistance = (targetPosition - hrp.Position).Magnitude
    local directionVector = (targetPosition - hrp.Position).Unit
    local initialRaycast = workspace:Raycast(hrp.Position, directionVector * currentDistance, rayParams)

    if not initialRaycast then
        humanoid:MoveTo(targetPosition)
        local trackingTimeout = tick() + (isWandering and 4.0 or 2.0)
        local velocityStuckSeconds = 0
        
        while Memory.IsFarming and humanoid.Health > 0 and (hrp.Position - targetPosition).Magnitude > 3.5 do
            if tick() > trackingTimeout then break end
            
            local floorRay = workspace:Raycast(hrp.Position - Vector3.new(0, 1.5, 0), hrp.CFrame.LookVector * 4, rayParams)
            if floorRay then humanoid.Jump = true end

            if hrp.AssemblyLinearVelocity.Magnitude < 2 then
                velocityStuckSeconds = velocityStuckSeconds + 0.05
                humanoid.Jump = true
                if velocityStuckSeconds > 1.0 then return false end
            else
                velocityStuckSeconds = 0
            end
            task.wait(0.05)
        end
        return true
    end

    local dynamicPath = PathfindingService:CreatePath({
        AgentRadius = 2.5,
        AgentHeight = 5.0,
        AgentCanJump = true
    })

    local calculationSuccess, _ = pcall(function()
        dynamicPath:ComputeAsync(hrp.Position, targetPosition)
    end)

    if calculationSuccess and dynamicPath.Status == Enum.PathStatus.Success then
        -- Skip the enthusiastic lightbulb jump if we are just casual wandering
        if not isWandering then
            humanoid.Jump = true 
            task.wait(0.1)
        end

        local structuralNodes = dynamicPath:GetWaypoints()
        local nodeCount = #structuralNodes
        local dynamicPathStartTime = tick()

        for index, node in ipairs(structuralNodes) do
            if not Memory.IsFarming or humanoid.Health <= 0 then break end

            if node.Action == Enum.PathWaypointAction.Jump then humanoid.Jump = true end

            if node.Position.Y > hrp.Position.Y + 0.4 then
                humanoid:ChangeState(Enum.HumanoidStateType.Climbing)
                humanoid.Jump = true
            end

            humanoid:MoveTo(node.Position)
            
            local executionTimeout = tick() + 1.2
            local distanceGoal = (index == nodeCount) and 3.0 or 4.5
            local physicalStuckTimeCounter = 0

            while Memory.IsFarming and humanoid.Health > 0 and (hrp.Position - node.Position).Magnitude > distanceGoal do
                if tick() > executionTimeout then break end
                
                local collisionScan = workspace:Raycast(hrp.Position, hrp.CFrame.LookVector * 5.0, rayParams)
                if collisionScan then humanoid.Jump = true end

                if hrp.AssemblyLinearVelocity.Magnitude < 3 then
                    physicalStuckTimeCounter = physicalStuckTimeCounter + 0.03
                    humanoid.Jump = true
                    if physicalStuckTimeCounter > 1.2 or (tick() - dynamicPathStartTime) > 8.0 then return false end
                    task.wait(0.03)
                else
                    physicalStuckTimeCounter = 0
                end
                task.wait()
            end
        end
        return true
    end
    return false
end

