local function loadOctree()
    if not Memory.OctreeModule then
        local success, result = pcall(function()
            return loadstring(game:HttpGet("https://raw.githubusercontent.com/Sleitnick/rbxts-octo-tree/main/src/init.lua", true))()
        end)
        if success then Memory.OctreeModule = result else warn("Failed to load Octree Engine.") end
    end
    return Memory.OctreeModule
end

local function updateStatusText(text)
    Memory.CurrentStatus = text
    local gui = player.PlayerGui:FindFirstChild("ProFarm_PremiumHUD")
    if gui then
        local statusLabel = gui:FindFirstChild("StatusLabel", true)
        if statusLabel then statusLabel.Text = "Status: " .. text end
    end
end

