-- 5. RUNTIME CONTROLLER LOOP
-- ==========================================
_G.StopFarm = function()
    Memory.IsFarming = false
    Memory.CurrentTargetCoin = nil
    updateStatusText("IDLE")
    
    local char = player.Character
    local humanoid = char and char:FindFirstChildOfClass("Humanoid")
    if humanoid then
        humanoid:MoveTo(char.PrimaryPart.Position)
        humanoid.WalkSpeed = 16 
    end

    if Config.ReturnToHome and Memory.HomeWaypoint and char and humanoid and humanoid.Health > 0 then
        updateStatusText("RETURNING HOME...")
        char:PivotTo(Memory.HomeWaypoint)
        updateStatusText("IDLE")
    end
end

_G.StartFarm = function()
    if Memory.IsFarming then return end
    Memory.IsFarming = true
    
    local character = player.Character or player.CharacterAdded:Wait()
    Memory.HomeWaypoint = character:GetPivot()
    
    local Octree = loadOctree()
    if not Octree then return end

    Memory.OctreeInstance = Octree.new()
    local mainGui = player.PlayerGui:WaitForChild("MainGUI", 5)

    task.spawn(function()
        while Memory.IsFarming do
            local currentCharacter = player.Character
            local currentHumanoid = currentCharacter and currentCharacter:FindFirstChildOfClass("Humanoid")
            
            if not currentCharacter or not currentHumanoid or currentHumanoid.Health <= 0 then
                updateStatusText("WAITING FOR RESPAWN...")
                task.wait(1)
                continue
            end

            local isBagFull = false
            if not Config.IgnoreFullBag and mainGui and mainGui:FindFirstChild("Game") then
                local bagIcon = mainGui.Game:FindFirstChild("CoinBags")
                if bagIcon and bagIcon.Container.SnowToken.FullBagIcon.Visible then
                    isBagFull = true
                end
            end

            if isBagFull then
                updateStatusText("BAG INVENTORY FULL")
                task.wait(1.5)
                continue
            end

            local map = nil
            for _, v in workspace:GetDescendants() do
                if v:IsA("Model") and v.Name == "Base" then map = v.Parent; break end
            end
            
            local container = map and map:FindFirstChild("CoinContainer")
            if not container then
                updateStatusText("SCANNING FOR DATA...")
                task.wait(1)
                continue
            end

            Memory.OctreeInstance:ClearAllNodes()
            local totalActiveCoinsOnMap = 0
            for _, item in pairs(container:GetDescendants()) do
                if item:IsA("TouchTransmitter") and item.Parent and not Memory.TouchedCoins[item.Parent] then
                    Memory.OctreeInstance:CreateNode(item.Parent.Position, item.Parent)
                    totalActiveCoinsOnMap = totalActiveCoinsOnMap + 1
                end
            end

            local hrp = currentCharacter:FindFirstChild("HumanoidRootPart")
            if not hrp then task.wait(0.5); continue end

            -- CASE A: EXECUTING TARGET PATH LOCK ON AN ACTIVE COIN
            if Memory.CurrentTargetCoin and Memory.CurrentTargetCoin.Parent and not Memory.TouchedCoins[Memory.CurrentTargetCoin] then
                updateStatusText("ACQUIRING COIN NODE")
                local pathCompleted = physicallyWalkTo(Memory.CurrentTargetCoin.Position, false)
                if not pathCompleted then
                    Memory.TouchedCoins[Memory.CurrentTargetCoin] = true
                end
                Memory.CurrentTargetCoin = nil
                task.wait(0.01)

            -- CASE B: NO TARGET LOCKED, ATTEMPTING TO ACQUIRE NEAREST COIN Part
            elseif totalActiveCoinsOnMap > 0 then
                Memory.CurrentTargetCoin = nil
                local searchResults = Memory.OctreeInstance:GetNearest(hrp.Position, Config.SearchRadius, 5)
                
                if #searchResults > 0 then
                    for _, result in ipairs(searchResults) do
                        if result.Object and not Memory.TouchedCoins[result.Object] then
                            Memory.CurrentTargetCoin = result.Object
                            break
                        end
                    end
                end
                
                if not Memory.CurrentTargetCoin then
                    updateStatusText("SCANNING COORDINATES...")
                    task.wait(0.2)
                end

            -- CASE C: NO COINS EXIST ON MAP -> TRIGGER HUMAN WANDER ENGINE
            else
                updateStatusText("WANDERING (LOOKING FOR COINS)")
                
                -- Pick a casual random direction offset from current position (between 30 to 75 studs away)
                local randomAngle = Memory.WanderSeed:NextNumber(0, math.pi * 2)
                local randomDistance = Memory.WanderSeed:NextNumber(30, 75)
                local wanderOffset = Vector3.new(math.cos(randomAngle) * randomDistance, 0, math.sin(randomAngle) * randomDistance)
                local targetWanderPosition = hrp.Position + wanderOffset
                
                -- Walk towards the wander node using path mechanics
                physicallyWalkTo(targetWanderPosition, true)
                
                -- Human factor: 40% chance to pause for a second at the destination to mimic checking angles
                if Memory.WanderSeed:NextNumber(0, 1) > 0.6 then
                    updateStatusText("WANDERING (IDLING)")
                    local stopTime = Memory.WanderSeed:NextNumber(1.0, 2.5)
                    task.wait(stopTime)
                else
                    task.wait(0.1)
                end
            end
        end
    end)
end

